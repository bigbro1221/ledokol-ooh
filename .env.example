# Database
POSTGRES_PORT="5433"
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/ooh_dashboard"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-secret-with-openssl-rand-base64-32"

# Google OAuth — obtain from https://console.cloud.google.com/
# Add http://localhost:3000/api/auth/callback/google as an authorized redirect URI.
# If omitted, the "Sign in with Google" button is hidden on the login page.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# MinIO (S3-compatible storage)
MINIO_ENDPOINT="localhost"
MINIO_PORT="9000"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="ooh-uploads"
MINIO_USE_SSL="false"

# Mapbox (public token — safe to expose client-side)
NEXT_PUBLIC_MAPBOX_TOKEN="your-mapbox-public-token"

# AWS SES (transactional email)
AWS_REGION="eu-central-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
SES_FROM_ADDRESS="noreply@ledokolgroup.com"
SES_SNS_TOPIC_ARN=""                        # optional — validates SNS webhook source
